{
  "name": "telegram-bridge",
  "version": "1.0.0",
  "description": "Control Claude Code CLI and OpenAI Codex CLI remotely from Telegram",
  "type": "module",
  "scripts": {
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "grammy": "^1.31.0",
    "node-pty": "^1.0.0",
    "dotenv": "^16.4.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
